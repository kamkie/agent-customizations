{
  "schemaVersion": 3,
  "targets": {
    "codex": {
      "displayName": "Codex",
      "homeEnvironmentVariable": "CODEX_HOME",
      "defaultHomeDirectory": ".codex",
      "instructions": {
        "source": "global/AGENTS.md",
        "destination": "AGENTS.md"
      },
      "hooks": {
        "destination": "hooks.json",
        "entries": [
          {
            "id": "managed-jobs-pre-tool-use",
            "event": "PreToolUse",
            "matcher": "^Bash$",
            "source": "skills/managed-jobs/scripts/ManagedJob.PreToolUseHook.ps1",
            "script": "skills/managed-jobs/scripts/ManagedJob.PreToolUseHook.ps1",
            "timeout": 10,
            "statusMessage": "Checking long-running process ownership"
          },
          {
            "id": "managed-jobs-stop",
            "event": "Stop",
            "source": "hooks/codex/managed-jobs/ManagedJob.StopHook.ps1",
            "script": "hooks/managed-jobs/ManagedJob.StopHook.ps1",
            "timeout": 15
          },
          {
            "id": "managed-jobs-session-end",
            "event": "SessionEnd",
            "source": "hooks/codex/managed-jobs/ManagedJob.SessionEndHook.ps1",
            "script": "hooks/managed-jobs/ManagedJob.SessionEndHook.ps1",
            "timeout": 3
          }
        ]
      },
      "skills": [
        "claude-runner",
        "dyslexia-friendly-formatter",
        "execute-campaign-work-item",
        "managed-jobs",
        "orchestrate-work-campaigns"
      ]
    },
    "claude": {
      "displayName": "Claude Code",
      "homeEnvironmentVariable": "CLAUDE_CONFIG_DIR",
      "defaultHomeDirectory": ".claude",
      "instructions": {
        "source": "global/CLAUDE.md",
        "destination": "CLAUDE.md"
      },
      "hooks": {
        "destination": "settings.json",
        "handlerFormat": "claude",
        "entries": [
          {
            "id": "managed-jobs-pre-tool-use",
            "event": "PreToolUse",
            "matcher": "^(Bash|PowerShell)$",
            "source": "skills/managed-jobs/scripts/ManagedJob.PreToolUseHook.ps1",
            "script": "skills/managed-jobs/scripts/ManagedJob.PreToolUseHook.ps1",
            "timeout": 10
          },
          {
            "id": "managed-jobs-stop",
            "event": "Stop",
            "source": "hooks/claude/managed-jobs/ManagedJob.StopHook.ps1",
            "script": "hooks/managed-jobs/ManagedJob.StopHook.ps1",
            "timeout": 15
          },
          {
            "id": "managed-jobs-stop-failure",
            "event": "StopFailure",
            "source": "hooks/claude/managed-jobs/ManagedJob.StopHook.ps1",
            "script": "hooks/managed-jobs/ManagedJob.StopHook.ps1",
            "timeout": 15
          },
          {
            "id": "managed-jobs-session-end",
            "event": "SessionEnd",
            "source": "hooks/claude/managed-jobs/ManagedJob.SessionEndHook.ps1",
            "script": "hooks/managed-jobs/ManagedJob.SessionEndHook.ps1",
            "timeout": 3
          }
        ]
      },
      "skills": [
        "dyslexia-friendly-formatter",
        "managed-jobs"
      ]
    }
  }
}
